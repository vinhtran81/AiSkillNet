@{
    ViewData["Title"] = "Skill.Net — Quản lý Hội viên";
}

<!-- Hero -->
<section class="relative flex flex-col items-center justify-center text-center py-28 px-6 overflow-hidden">
    <!-- Glows -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-[-15%] right-[10%] w-[600px] h-[600px] rounded-full blur-[120px]" style="background:rgba(255,80,0,.1)"></div>
        <div class="absolute bottom-[-20%] left-[5%] w-[500px] h-[500px] rounded-full blur-[100px]" style="background:rgba(99,102,241,.06)"></div>
        <div class="absolute inset-0 opacity-[0.025]" style="background-image:radial-gradient(#FF5000 1px,transparent 1px);background-size:32px 32px"></div>
    </div>

    <div class="relative z-10 max-w-3xl">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-sm font-bold mb-6"
             style="background:rgba(255,80,0,.1);border-color:rgba(255,80,0,.2);color:#FF5000">
            <span class="material-symbols-outlined" style="font-size:16px">fitness_center</span>
            Hệ thống quản lý hội viên
        </div>

        <h1 class="font-black text-white leading-tight mb-5" style="font-size:clamp(2.5rem,5vw,4rem);letter-spacing:-.04em">
            Quản lý hội viên<br />
            <span style="color:#FF5000">đơn giản & hiệu quả</span>
        </h1>

        <p class="text-lg leading-relaxed mx-auto mb-10 max-w-xl" style="color:#b0a090">
            Đăng ký gói thành viên, theo dõi đơn và nhận thông báo — tất cả trong một nền tảng duy nhất.
        </p>

        <div class="flex items-center justify-center gap-3 flex-wrap">
            <a asp-controller="ServicePackage" asp-action="Index"
               class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-base font-bold text-white no-underline transition-all"
               style="background:#FF5000;box-shadow:0 0 24px rgba(255,80,0,.3)">
                <span class="material-symbols-outlined" style="font-size:20px">explore</span>
                Xem gói hội viên
            </a>
            @if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <a asp-controller="Account" asp-action="Register"
                   class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-base font-semibold no-underline border transition-all"
                   style="border-color:#33302a;color:#b0a090">
                    Đăng ký miễn phí
                    <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
                </a>
            }
        </div>
    </div>
</section>

<!-- Feature cards -->
<section class="px-6 pb-24 max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="rounded-xl p-6 border" style="background:#201e1a;border-color:#33302a">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(255,80,0,.1)">
                <span class="material-symbols-outlined" style="color:#FF5000;font-size:22px">assignment_turned_in</span>
            </div>
            <h3 class="font-bold text-white mb-2">Đăng ký online</h3>
            <p class="text-sm leading-relaxed" style="color:#b0a090">Nộp đơn đăng ký gói hội viên mọi lúc, mọi nơi. Không cần đến trực tiếp.</p>
        </div>
        <div class="rounded-xl p-6 border" style="background:#201e1a;border-color:#33302a">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(34,197,94,.08)">
                <span class="material-symbols-outlined" style="color:#4ade80;font-size:22px">track_changes</span>
            </div>
            <h3 class="font-bold text-white mb-2">Theo dõi trạng thái</h3>
            <p class="text-sm leading-relaxed" style="color:#b0a090">Xem tiến trình xét duyệt đơn theo thời gian thực. Minh bạch từ đầu đến cuối.</p>
        </div>
        <div class="rounded-xl p-6 border" style="background:#201e1a;border-color:#33302a">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(99,102,241,.1)">
                <span class="material-symbols-outlined" style="color:#818cf8;font-size:22px">notifications_active</span>
            </div>
            <h3 class="font-bold text-white mb-2">Thông báo đa kênh</h3>
            <p class="text-sm leading-relaxed" style="color:#b0a090">Nhận thông báo qua email và Zalo ngay khi đơn được duyệt hoặc từ chối.</p>
        </div>
    </div>
</section>
