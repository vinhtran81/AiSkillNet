@model SkillNet.Application.Features.Membership.Queries.GetApplicationDetail.ApplicationDetailDto
@using SkillNet.Domain.Enums
@{
    ViewData["Title"] = "Chi tiết đơn";
}

<div style="max-width:760px;margin:0 auto;padding:2.5rem 1.5rem">
    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:2rem">
        <a asp-action="Pending" class="sn-btn-ghost" style="min-height:36px;padding:.35rem .8rem;font-size:.85rem">
            <span class="material-symbols-outlined" style="font-size:17px">arrow_back</span>
            Quay lại
        </a>
        <h1 style="font-size:1.5rem;font-weight:800;letter-spacing:-.03em;margin:0">Chi tiết đơn</h1>
    </div>

    <div class="card" style="margin-bottom:1.5rem">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@Model.FullName</span>
            <span class="status-badge status-pending">
                <span class="status-dot"></span>
                Chờ duyệt — @Model.DaysPending ngày
            </span>
        </div>
        <div class="card-body" style="padding:1.5rem">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem 2rem">
                <div>
                    <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Ngày sinh</div>
                    <div style="font-weight:600">@Model.DateOfBirth.ToString("dd/MM/yyyy")</div>
                </div>
                <div>
                    <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Số điện thoại</div>
                    <div style="font-weight:600">@Model.PhoneNumber</div>
                </div>
                <div style="grid-column:span 2">
                    <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Địa chỉ</div>
                    <div style="font-weight:600">@Model.Address</div>
                </div>
                <div>
                    <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Gói đăng ký</div>
                    <div style="font-weight:600">@Model.ServicePackageName</div>
                </div>
                <div>
                    <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Giá</div>
                    <div style="font-weight:700;color:var(--primary)">@Model.ServicePackagePrice.ToString("N0")đ</div>
                </div>
                @if (Model.Notes != null)
                {
                    <div style="grid-column:span 2">
                        <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Ghi chú</div>
                        <div style="color:var(--text-2)">@Model.Notes</div>
                    </div>
                }
                @if (Model.IdDocumentPath != null)
                {
                    <div>
                        <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">CMND/CCCD</div>
                        <a href="@Model.IdDocumentPath" target="_blank" class="d-inline-flex align-items-center gap-1" style="font-size:.875rem">
                            <span class="material-symbols-outlined" style="font-size:16px">attach_file</span>
                            Xem tài liệu
                        </a>
                    </div>
                }
                <div>
                    <div style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.3rem">Ngày nộp đơn</div>
                    <div style="font-weight:600">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Status == ApplicationStatus.Pending)
    {
        <div style="display:flex;gap:.75rem;align-items:center">
            <form asp-action="Approve" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Xác nhận phê duyệt hội viên này?')">
                <button type="submit" class="btn btn-success d-inline-flex align-items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size:18px">check_circle</span>
                    Phê duyệt
                </button>
            </form>
            <button type="button" class="btn btn-danger d-inline-flex align-items-center gap-1"
                    data-bs-toggle="modal" data-bs-target="#rejectModal">
                <span class="material-symbols-outlined" style="font-size:18px">cancel</span>
                Từ chối
            </button>
        </div>

        <!-- Reject modal -->
        <div class="modal fade" id="rejectModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content" style="background:var(--card);border:1px solid var(--border)">
                    <div class="modal-header" style="border-bottom:1px solid var(--border)">
                        <h5 class="modal-title" style="font-weight:700">Từ chối đơn đăng ký</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                        <div class="modal-body">
                            @{
                                var rejectForm = ViewBag.RejectForm as SkillNet.Web.ViewModels.RejectApplicationFormModel
                                    ?? new SkillNet.Web.ViewModels.RejectApplicationFormModel();
                            }
                            <div class="mb-3">
                                <label class="form-label">Lý do từ chối <span style="color:var(--danger)">*</span></label>
                                <textarea name="RejectionReason" class="form-control" rows="4"
                                          placeholder="Vui lòng nhập lý do cụ thể...">@rejectForm.RejectionReason</textarea>
                                @{
                                    var rejectError = ViewData.ModelState["RejectionReason"]?.Errors.FirstOrDefault()?.ErrorMessage;
                                }
                                @if (rejectError != null)
                                {
                                    <span class="field-validation-error">@rejectError</span>
                                }
                            </div>
                        </div>
                        <div class="modal-footer" style="border-top:1px solid var(--border)">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-danger">Xác nhận từ chối</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
